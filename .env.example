# Feltrim Agents Base - Environment Template
# Copie para .env e preencha. NUNCA commitar .env.

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Database (opcional - apenas se usar Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Integracoes opcionais
OPENCLAW_PORT=3100
N8N_HOST=
N8N_PORT=5678

# Telegram / WhatsApp (opcional)
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_KEY=

# Observabilidade (opcional)
LOG_LEVEL=info
